# ── Docker Images (set by CI/CD, override only if using a custom registry) ───
API_IMAGE=ghcr.io/joshue000/fx-back:latest
FRONTEND_IMAGE=ghcr.io/joshue000/fx-front:latest

# ── Ports ────────────────────────────────────────────────────────────────────
API_PORT=3000
FRONTEND_PORT=80
PROMETHEUS_PORT=9090
GRAFANA_PORT=3100

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=fxreplaychallenge
DB_HOST=localhost
DB_PORT=5432

# Prisma connection string (used when seeding from the host)
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public"

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
